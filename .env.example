# Local Code Signing & Notarization Configuration
# Copy this file to .env and fill in your values for local release builds.
# NEVER commit the real .env file.
#
# Note:
# - Local builds still use the Electron Builder env var names below.
# - GitHub Actions uses repository secrets with different names:
#   CSC_NAME <- MACOS_SIGNING_IDENTITY
#   CSC_KEY_PASSWORD <- MACOS_CERTIFICATE_PASSWORD
#   CSC_LINK <- MACOS_CERTIFICATE_P12_BASE64
#   TEAM_ID <- APPLE_TEAM_ID

# Apple Developer ID for code signing
# Find with: security find-identity -v -p codesigning
CSC_NAME="Developer ID Application: Your Name (TEAM_ID)"

# Certificate password for your exported .p12
CSC_KEY_PASSWORD=""

# Local path to your .p12 certificate, or base64 content if you prefer
CSC_LINK=""

# Apple ID for notarization
APPLE_ID="your-apple-id@example.com"

# Apple App-Specific Password
# Generate at: https://appleid.apple.com/account/manage
APPLE_APP_SPECIFIC_PASSWORD=""

# Apple Developer Team ID
# Find at: https://developer.apple.com/account/#/membership
TEAM_ID=""


