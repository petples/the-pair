# Code Signing & Notarization Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env file to Git!

# Apple Developer ID for code signing
# Find with: security find-identity -v -p codesigning
CSC_NAME="Developer ID Application: Your Name (TEAM_ID)"

# Certificate password (if using .p12 file)
CSC_KEY_PASSWORD=""

# Path to .p12 certificate file (base64 encoded for CI/CD)
CSC_LINK=""

# Apple ID for notarization
APPLE_ID="your-apple-id@example.com"

# Apple App-Specific Password
# Generate at: https://appleid.apple.com/account/manage
APPLE_APP_SPECIFIC_PASSWORD=""

# Apple Developer Team ID
# Find at: https://developer.apple.com/account/#/membership
TEAM_ID=""

# Homebrew GitHub Token (for auto-updating cask)
HOMEBREW_GITHUB_TOKEN=""
